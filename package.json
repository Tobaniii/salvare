{
  "name": "salvare",
  "private": true,
  "version": "0.47.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "build:extension": "esbuild extension/contentScript.ts --bundle --outfile=extension/contentScript.js && esbuild extension/popup.ts --bundle --outfile=extension/popup.js && esbuild extension/background.ts --bundle --format=esm --outfile=extension/background.js",
    "build:server": "esbuild server/main.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/server.js --external:better-sqlite3",
    "start:server": "node server/server.js",
    "build:db-init": "esbuild server/db-init.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/db-init.js --external:better-sqlite3",
    "db:init": "npm run build:db-init && node server/db-init.js",
    "build:db-bootstrap": "esbuild server/db-bootstrap-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/db-bootstrap-cli.js --external:better-sqlite3",
    "db:bootstrap": "npm run build:db-bootstrap && node server/db-bootstrap-cli.js",
    "build:db-backup": "esbuild server/db-backup-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/db-backup-cli.js --external:better-sqlite3",
    "db:backup": "npm run build:db-backup && node server/db-backup-cli.js",
    "build:db-export": "esbuild server/db-export-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/db-export-cli.js --external:better-sqlite3",
    "db:export": "npm run build:db-export && node server/db-export-cli.js",
    "build:db-reset": "esbuild server/db-reset-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/db-reset-cli.js --external:better-sqlite3",
    "db:reset": "npm run build:db-reset && node server/db-reset-cli.js",
    "build:db-import": "esbuild server/db-import-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/db-import-cli.js --external:better-sqlite3",
    "db:import": "npm run build:db-import && node server/db-import-cli.js",
    "build:db-verify": "esbuild server/db-verify-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/db-verify-cli.js --external:better-sqlite3",
    "db:verify": "npm run build:db-verify && node server/db-verify-cli.js",
    "build:source-refresh": "esbuild server/source-refresh-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/source-refresh-cli.js --external:better-sqlite3",
    "source:refresh": "npm run build:source-refresh && node server/source-refresh-cli.js",
    "build:profiles-verify": "esbuild server/profiles-verify-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=server/profiles-verify-cli.js --packages=external",
    "profiles:verify": "npm run build:profiles-verify && node server/profiles-verify-cli.js",
    "build:extension-harness": "esbuild smoke/extension-server-harness.ts --bundle --platform=node --target=node20 --format=esm --outfile=smoke/extension-server-harness.js --external:better-sqlite3",
    "test:smoke": "playwright test --project=chromium",
    "test:smoke:extension": "npm run build:extension && npm run build:extension-harness && playwright test --project=extension",
    "test:smoke:all": "npm run test:smoke && npm run test:smoke:extension",
    "test:all": "npm test -- --run && npm run test:smoke:all",
    "verify:build": "npx tsc -b && npm run build:server && npm run build:extension",
    "verify:unit": "npm test -- --run",
    "verify:data": "npm run db:verify && npm run profiles:verify",
    "verify:smoke": "npm run test:smoke",
    "verify:extension": "npm run test:smoke:extension",
    "verify:local": "npm run verify:build && npm run verify:unit && npm run verify:data && npm run verify:smoke"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chrome": "^0.1.40",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
